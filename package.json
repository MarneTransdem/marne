    "@vitejs/plugin-react": "^5.0.4",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "helmet": "^8.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.7",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
