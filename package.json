    "optimize:images": "node scripts/optimize-referenced-images.mjs",
    "optimize:images:recompress": "node scripts/optimize-referenced-images.mjs --recompress-webp",
    "check": "npm run audit:site && npm run lint && npm run build"
  },
  "dependencies": {
