{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with specific role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["gérant", "secrétaire", "commercial", "chef_equipe"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Devis": {
      "title": "Devis",
      "description": "Déménagement quote",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "devis/{devisId}": {
        "schema": "Devis",
        "description": "Quotes collection"
    }
  }
}
