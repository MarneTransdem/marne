rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin helper - check if user email is the owner's email
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'contact@marnetransdem.com';
    }
    
    // Role-based helpers
    function hasUidRole(role) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != 'Inactif';
    }

    function hasEmailRole(role) {
      return isSignedIn()
        && request.auth.token.email is string
        && exists(/databases/$(database)/documents/userRolesByEmail/$(request.auth.token.email))
        && get(/databases/$(database)/documents/userRolesByEmail/$(request.auth.token.email)).data.role == role
        && get(/databases/$(database)/documents/userRolesByEmail/$(request.auth.token.email)).data.status != 'Inactif';
    }
    
    function hasRole(role) {
      return isSignedIn() && (isAdmin() || hasUidRole(role) || hasEmailRole(role));
    }

    function isManager() {
      return hasRole('gérant');
    }

    function isSecretary() {
      return hasRole('secrétaire');
    }

    function isCommercial() {
      return hasRole('commercial');
    }

    function isTeamLead() {
      return hasRole('chef_equipe');
    }

    function isOfficeStaff() {
      return isManager() || isSecretary();
    }

    function isSalesStaff() {
      return isOfficeStaff() || isCommercial();
    }

    function isOperationsStaff() {
      return isSalesStaff() || isTeamLead();
    }

    // --- Collections ---

    // 0. Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isManager());
      allow create, update, delete: if isManager();
    }

    // 0.b CRM role mirror by email, used by Google sign-in.
    match /userRolesByEmail/{email} {
      allow read: if isSignedIn() && (request.auth.token.email == email || isManager());
      allow create, update, delete: if isManager();
    }

    // 1. Quotes
    match /quotes/{quoteId} {
      allow create: if isValidQuote(incoming());
      allow read: if isSalesStaff();
      allow update: if isSalesStaff();
      allow delete: if isOfficeStaff();
      
      function isValidQuote(data) {
        return data.keys().hasAll(['fullName', 'phone', 'email', 'fromAddress', 'fromCity', 'fromZip', 'toAddress', 'toCity', 'toZip', 'date', 'housingType', 'surface', 'formula', 'createdAt'])
          && data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 100
          && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 25
          && data.email is string && data.email.matches('^.+@.+\\..+$')
          && data.fromAddress is string && data.fromAddress.size() <= 200
          && data.fromCity is string && data.fromCity.size() <= 100
          && data.fromZip is string && data.fromZip.size() <= 20
          && data.toAddress is string && data.toAddress.size() <= 200
          && data.toCity is string && data.toCity.size() <= 100
          && data.toZip is string && data.toZip.size() <= 20
          && data.date is string && data.date.size() <= 50
          && data.housingType is string && data.housingType.size() <= 50
          && data.surface is string && data.surface.size() <= 50
          && data.formula is string && data.formula.size() <= 50
          && data.createdAt == request.time;
      }
    }

    // 2. Messages
    match /messages/{messageId} {
      allow create: if isValidMessage(incoming());
      allow read, update, delete: if isOfficeStaff();

      function isValidMessage(data) {
        return data.keys().hasAll(['name', 'phone', 'email', 'subject', 'message', 'createdAt'])
          && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
          && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 25
          && data.email is string && data.email.matches('^.+@.+\\..+$')
          && data.subject is string && data.subject.size() <= 100
          && data.message is string && data.message.size() >= 5 && data.message.size() <= 2000
          && data.createdAt == request.time;
      }
    }

    // 3. Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isManager() && isValidReview(incoming());
      allow delete: if isManager();

      function isValidReview(data) {
        return data.authorName is string && data.authorName.size() <= 150
          && data.rating is number && data.rating >= 0 && data.rating <= 5
          && data.text is string && data.text.size() <= 6000
          && (data.createdAt == request.time);
      }
    }

    // 4. Admin CRM collections
    match /devis/{devisId} {
      allow read, create, update: if isSalesStaff();
      allow delete: if isOfficeStaff();
    }

    match /factures/{factureId} {
      allow read, write: if isOfficeStaff();
    }

    match /visites/{visiteId} {
      allow read, write: if isSalesStaff();
    }

    match /demenagements/{moveId} {
      allow read: if isOperationsStaff();
      allow create, delete: if isOfficeStaff();
      allow update: if isOfficeStaff()
        || (isTeamLead() && incoming().diff(resource.data).affectedKeys().hasOnly(['status']));
    }

    match /dossierNotes/{noteId} {
      allow read, write: if isOperationsStaff();
    }

    match /dossierTasks/{taskId} {
      allow read, write: if isOperationsStaff();
    }

    match /dossierOwners/{ownerId} {
      allow read, write: if isOperationsStaff();
    }

    match /collaborateurs/{collaborateurId} {
      allow read, write: if isManager();
    }

    match /movers/{moverId} {
      allow read: if isOperationsStaff();
      allow write: if isOfficeStaff();
    }

    match /trucks/{truckId} {
      allow read: if isOperationsStaff();
      allow write: if isOfficeStaff();
    }
  }
}
